generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Shop {
  id     String  @id @default(cuid())
  name   String  @unique
  url    String
  prices Price[]
}

model Card {
  id       String        @id @default(cuid())
  name     String
  nameJa   String?
  oracleId String?
  variants CardVariant[]

  @@index([name])
  @@index([nameJa])
}

model CardVariant {
  id              String  @id @default(cuid())
  cardId          String
  scryfallId      String?
  setCode         String
  collectorNumber String
  language        String
  isFoil          Boolean @default(false)
  image           String?
  finish          String  @default("nonfoil")
  frameEffects    String?
  promoTypes      String?
  card            Card    @relation(fields: [cardId], references: [id])
  prices          Price[]

  @@unique([setCode, collectorNumber, language, finish])
  @@index([cardId])
  @@index([setCode])
}

model Price {
  id            String      @id @default(cuid())
  variantId     String
  shopId        String
  priceYen      Int
  buyPriceYen   Int?
  stock         Int         @default(0)
  sourceUrl     String?
  timestamp     DateTime    @default(now())
  sellSourceUrl String?
  shop          Shop        @relation(fields: [shopId], references: [id])
  variant       CardVariant @relation(fields: [variantId], references: [id])

  @@index([variantId])
  @@index([shopId])
}
